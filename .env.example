# OpenAI 兼容代理地址（tech.md 提供 http://localhost:4141）
# Docker 部署且代理在宿主机时，用 http://host.docker.internal:4141/v1
OPENAI_BASE_URL=http://localhost:4141/v1
OPENAI_API_KEY=dummy

# 对话主模型与降级模型（均需支持 /chat/completions）
# 实测可用：claude-opus-4.6 / claude-sonnet-4.6 / gpt-4.1
# 注意：gpt-5.5 只支持 responses API，不能用；tech.md 里的 claude-ops-4.6 是笔误，实际 id 是 claude-opus-4.6
MODEL_PRIMARY=claude-opus-4.6
MODEL_FALLBACK=gpt-4.1

# 主持人控制台口令
HOST_KEY=whoisai

# 服务端口
PORT=3000
